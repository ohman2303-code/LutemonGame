<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:background="#F44336"
    android:padding="10dp">

    <ImageView
        android:id="@+id/imageViewLutemon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        app:srcCompat="@drawable/lutemon_turqoise" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_toEndOf="@id/imageViewLutemon"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lutemonName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#F4F0F0"
            android:backgroundTint="#F44336"
            android:text="Nimi"
            android:textColor="#FFFFFF"
            android:textColorHint="#F20000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lutemonHealth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FBE2DFDA"
            android:backgroundTint="#F44336"
            android:text="HP: 0"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/lutemonAttack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#EBE8E4"
            android:backgroundTint="#F44336"
            android:text="ATK: 0"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/lutemonDefence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DEF: 0"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/lutemonExp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#E7E3DD"
            android:backgroundTint="#F44336"
            android:text="EXP: 0"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

</RelativeLayout>