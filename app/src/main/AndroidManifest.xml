<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LutemonGame">
        <activity
            android:name=".activites.FightActivity"
            android:exported="false" />
        <activity
            android:name=".activites.ListLutemonsActivity"
            android:exported="false" />
        <activity
            android:name=".activites.MoveLutemonsActivity"
            android:exported="false" />
        <activity
            android:name=".FragmentsActivity"
            android:exported="false" />
        <activity
            android:name=".activites.AddLutemonActivity"
            android:exported="false" />
        <activity
            android:name=".activites.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>